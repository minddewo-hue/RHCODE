# Copy this file to desktop/.env for local source development.
# Never commit desktop/.env or replace these placeholders with real secrets here.

# Configure the model.rhzy.ai provider for desktop/gateway.config.json.
# SUB2API_API_KEY=replace-with-your-sub2api-api-key

# Embedded model gateway settings.
GATEWAY_CONFIG=gateway.config.json
LOG_LEVEL=info
REQUEST_BODY_LIMIT=50mb
UPSTREAM_TIMEOUT_MS=600000

# Desktop-to-mobile control plane defaults.
RHZYCODE_SYNC_HOST=0.0.0.0
RHZYCODE_SYNC_PORT=8790

# Optional desktop runtime overrides.
# RHZYCODE_CODEX_PATH=C:\path\to\codex.exe
# RHZYCODE_CODEX_HOME=C:\path\to\isolated-codex-home
# RHZYCODE_GATEWAY_HOME=C:\path\to\gateway-runtime-files
# RHZYCODE_USER_DATA_DIR=C:\path\to\isolated-user-data
# RHZYCODE_STARTUP_TRACE=1

# Optional TLS for non-loopback mobile access. Configure CERT and KEY together.
# RHZYCODE_SYNC_TLS_CERT=C:\secure\control-fullchain.pem
# RHZYCODE_SYNC_TLS_KEY=C:\secure\control-private-key.pem
# RHZYCODE_SYNC_TLS_CA=C:\secure\control-ca.pem

# Optional signed desktop update channel.
# RHZYCODE_UPDATE_URL=https://updates.example.com/rhzycode/windows
# RHZYCODE_REQUIRE_SIGNING=1
