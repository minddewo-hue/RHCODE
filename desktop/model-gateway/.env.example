# The JSON file contains routing metadata only. Keep all secrets in environment variables.
GATEWAY_CONFIG=gateway.config.json
RHZY_GATEWAY_API_KEY=replace-with-a-new-local-gateway-key
FAKER_API_KEY=replace-with-a-rotated-faker-key
SUB2API_API_KEY=replace-with-your-sub2api-key

HOST=127.0.0.1
PORT=8787
LOG_LEVEL=info
REQUEST_BODY_LIMIT=50mb
UPSTREAM_TIMEOUT_MS=600000
