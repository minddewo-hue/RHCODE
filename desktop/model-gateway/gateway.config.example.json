{
  "providers": {
    "sub2api": {
      "base_url": "https://model.rhzy.ai/v1",
      "protocol": "responses",
      "api_key_env": "SUB2API_API_KEY"
    }
  },
  "models": {
    "sub2api/gpt-codex": {
      "provider": "sub2api",
      "upstream_model": "gpt-5.5",
      "capabilities": {
        "function_tools": true,
        "parallel_tool_calls": true,
        "image_input": true,
        "reasoning": true,
        "streaming": true
      }
    }
  },
  "access": [
    {
      "api_key_env": "RHZY_GATEWAY_API_KEY",
      "models": ["sub2api/*"]
    }
  ],
  "upstream_timeout_ms": 600000,
  "sticky_ttl_ms": 3600000,
  "circuit_breaker": {
    "failure_threshold": 3,
    "cooldown_ms": 30000
  }
}
