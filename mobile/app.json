{
  "expo": {
    "name": "RHZYCODE",
    "slug": "rhzycode",
    "version": "0.1.13",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ai.rhzy.code",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocalNetworkUsageDescription": "RHZYCODE connects to your desktop agent on the local network.",
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        }
      }
    },
    "android": {
      "package": "ai.rhzy.code",
      "versionCode": 14,
      "permissions": [
        "REQUEST_INSTALL_PACKAGES"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#202620"
      }
    },
    "plugins": [
      "expo-secure-store",
      "expo-status-bar",
      [
        "expo-media-library",
        {
          "photosPermission": "允许 RHZYCODE 访问相册中的图片。",
          "savePhotosPermission": "允许 RHZYCODE 将生成的图片保存到相册。",
          "granularPermissions": [
            "photo"
          ]
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "允许 RHZYCODE 使用相机拍摄附件。",
          "photosPermission": "允许 RHZYCODE 从相册选择附件。",
          "microphonePermission": false
        }
      ],
      "./plugins/with-android-local-toolchain.cjs",
      "./plugins/with-private-network-cleartext.cjs"
    ],
    "extra": {
      "updateManifestUrl": "https://minio.gshbzw.com/wxfile/rhzycode/version.json"
    }
  }
}
