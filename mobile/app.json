{
  "expo": {
    "name": "RHZYCODE",
    "slug": "rhzycode",
    "version": "0.1.5",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ai.rhzy.code"
    },
    "android": {
      "package": "ai.rhzy.code",
      "versionCode": 6,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#202620"
      }
    },
    "plugins": [
      "expo-secure-store",
      "expo-status-bar",
      "./plugins/with-private-network-cleartext.cjs"
    ],
    "extra": {
      "updateManifestUrl": "http://192.168.11.103:8791/manifest.json"
    }
  }
}
