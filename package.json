{
  "name": "rhzycode",
  "version": "0.1.0",
  "private": true,
  "description": "RHZYCODE cross-platform coding agent",
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "appupdate",
    "desktop",
    "mobile",
    "packages/*",
    "services/*",
    "transfer"
  ],
  "scripts": {
    "dev:desktop": "npm run dev --workspace @rhzycode/desktop",
    "dev:mobile": "npm run start --workspace @rhzycode/mobile",
    "dev:control": "npm run dev --workspace @rhzycode/control-plane",
    "update:serve": "node appupdate/server.mjs",
    "update:build:desktop": "node appupdate/scripts/build-desktop.mjs",
    "update:build:mobile": "node appupdate/scripts/build-mobile.mjs",
    "update:publish": "node appupdate/scripts/publish.mjs",
    "update:release": "npm run update:build:desktop && npm run update:build:mobile && npm run update:publish",
    "gateway:test": "npm test --workspace @rhzycode/model-gateway",
    "gateway:catalog": "npm run catalog --workspace @rhzycode/model-gateway",
    "postinstall": "node node_modules/electron/install.js",
    "build": "npm run build --workspace @rhzycode/protocol && npm run build --workspace @rhzycode/control-plane && npm run build --workspace @rhzycode/desktop",
    "pack:desktop": "npm run pack:win --workspace @rhzycode/desktop",
    "dist:desktop": "npm run dist:win --workspace @rhzycode/desktop",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "check": "npm run typecheck && npm run test"
  },
  "engines": {
    "node": ">=20"
  }
}
